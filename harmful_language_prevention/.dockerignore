# Axiom Hive Docker Ignore
# Created by Nicholas Michael Grossi

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
env/
venv/
ENV/
.venv/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore

# Logs (will be mounted as volume)
logs/
*.log

# Test and documentation artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# OS files
.DS_Store
Thumbs.db

# Docker files (avoid recursion)
Dockerfile
docker-compose.yml
.dockerignore

# Documentation (not needed in container)
*.md
!PROMPT_TEMPLATE.md
!SYSTEM_PROMPT.txt

# Local proofs directory (mounted as volume)
proofs/
